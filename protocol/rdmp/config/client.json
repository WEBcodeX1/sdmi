{
    "global": {
        "synctype": "s3"
    },
    "multicast": {
        "group": "239.1.2.3",
        "port": 5000,
        "ttl": 32,
        "interface": ""
    },
    "s3": {
        "endpoint": "http://s3.internal.example.com:9000",
        "endpoints": [],
