# RDMP Server Configuration Example
# Copy to server.conf and adjust values for your deployment.

[multicast]
# IPv4 multicast group address – must match the client configuration
group = 239.1.2.3
# UDP port – must match the client configuration
port = 5000
# TTL is not significant for receivers, but kept here for documentation symmetry
ttl = 32
# Optional: network interface to join the multicast group on.
# Leave empty to use INADDR_ANY (all interfaces).
interface =

[s3]
# HTTP endpoint of the Ceph/S3-compatible object storage backend
endpoint = http://s3.internal.example.com:9000
# Shared task-queue bucket – must match the client configuration
bucket = rdmp-tasks
# AWS / Ceph access credentials (leave empty for anonymous access)
access_key = your-access-key
secret_key = your-secret-key
# S3 region (used for AWS Signature Version 4 scope)
region = us-east-1

[timeouts]
# Maximum time (ms) allowed for a task to complete
task_execution_ms = 5000
# S3 poll interval is used by clients; set here for completeness / future server polling
s3_poll_interval_ms = 1000
# Delay (ms) before retrying a failed/timed-out task (reserved for future use)
retry_delay_ms = 3000
# Burst repeat settings are client-side; kept here for reference
multicast_repeat_count = 3
multicast_repeat_interval_ms = 100

[node]
# Unique identifier for this server instance (written to the S3 status record)
id = server1
