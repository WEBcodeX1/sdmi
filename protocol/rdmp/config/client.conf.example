# RDMP Client Configuration Example
# Copy to client.conf and adjust values for your deployment.

[multicast]
# IPv4 multicast group address (239.0.0.0/8 is the administratively-scoped range)
group = 239.1.2.3
# UDP port shared by all clients and servers in this RDMP cluster
port = 5000
# IP TTL for outgoing multicast packets (1 = local LAN, 32 = site-scope)
ttl = 32
# Optional: name of the network interface to use for multicast sending.
# Leave empty to use the system default route.
interface =

[s3]
# HTTP endpoint of the Ceph/S3-compatible object storage backend
endpoint = http://s3.internal.example.com:9000
# Bucket used as the shared task queue
bucket = rdmp-tasks
# AWS / Ceph access credentials (leave empty for anonymous access)
access_key = your-access-key
secret_key = your-secret-key
# S3 region (used for AWS Signature Version 4 scope)
region = us-east-1

[timeouts]
# Maximum time (ms) allowed for a task to complete before the watchdog retries it
task_execution_ms = 5000
# Interval (ms) between S3 bucket polls for new tasks from other clients
s3_poll_interval_ms = 1000
# Latency threshold (ms) beyond which a controller is considered degraded
degradation_threshold_ms = 2000
# Interval (ms) between watchdog runs (server-side setting, ignored by client)
watchdog_interval_ms = 2000
# Delay (ms) before retrying a failed/timed-out task
retry_delay_ms = 3000
# Number of UDP multicast datagrams sent per task announcement (burst count)
multicast_repeat_count = 3
# Interval (ms) between successive datagrams in a burst
multicast_repeat_interval_ms = 100

[node]
# Unique identifier for this client instance (used in task metadata and alerts)
id = client1
